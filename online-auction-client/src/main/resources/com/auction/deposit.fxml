<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.Spinner?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.auction.DepositController"
           prefWidth="700"
           prefHeight="600"
           stylesheets="@style.css">

    <Region styleClass="deposit-overlay"/>

    <VBox fx:id="depositRoot"
          alignment="TOP_CENTER"
          spacing="15"
          prefWidth="400"
          prefHeight="480"
          styleClass="deposit-popup">

        <padding>
            <Insets top="25" right="25" bottom="25" left="25"/>
        </padding>

        <HBox alignment="CENTER_LEFT" spacing="15">
            <Label text="💳" styleClass="deposit-icon"/>
            <Label text="Nạp Số Dư" styleClass="deposit-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleClose" styleClass="deposit-close-btn"/>
        </HBox>

        <GridPane hgap="10" vgap="10" alignment="CENTER">
            <Button fx:id="btn10k" text="+$10,000" prefWidth="170" prefHeight="65"
                    GridPane.columnIndex="0" GridPane.rowIndex="0" styleClass="deposit-amount-btn"/>
            <Button fx:id="btn50k" text="+$50,000" prefWidth="170" prefHeight="65"
                    GridPane.columnIndex="1" GridPane.rowIndex="0" styleClass="deposit-amount-btn"/>
            <Button fx:id="btn100k" text="+$100,000" prefWidth="170" prefHeight="65"
                    GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="deposit-amount-btn"/>
            <Button fx:id="btn500k" text="+$500,000" prefWidth="170" prefHeight="65"
                    GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="deposit-amount-btn"/>
        </GridPane>

        <VBox spacing="8" alignment="CENTER_LEFT">
            <Label text="HOẶC NHẬP SỐ TIỀN TÙY CHỈNH" styleClass="deposit-subtitle"/>
            <HBox alignment="CENTER_LEFT" spacing="10" prefHeight="55" 
                  prefWidth="350" styleClass="deposit-input-wrapper">
                <Label text="\$" styleClass="deposit-dollar"/>
                <Spinner fx:id="spinnerAmount" editable="true" 
                         prefWidth="290" prefHeight="45" styleClass="deposit-spinner"/>
            </HBox>
        </VBox>

        <Label fx:id="lblMessage" styleClass="deposit-msg"/>

        <Button fx:id="btnConfirm"
                text="XÁC NHẬN NẠP"
                prefWidth="350" 
                prefHeight="55"
                onAction="#handleDeposit"
                styleClass="deposit-confirm-btn"/>

    </VBox>
</StackPane>