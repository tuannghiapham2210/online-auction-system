<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.DashboardController">

   <BorderPane styleClass="dashboard-root" stylesheets="@style.css">

   <left>
      <VBox prefWidth="250.0" spacing="20.0" styleClass="sidebar">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
         <children>
            <Label text="THE AUCTION SYSTEM"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField fx:id="searchField"
                       promptText="Tìm kiếm lô hàng..."
                       style="-fx-background-color: #2D3748; -fx-text-fill: white; -fx-background-radius: 10;" />

            <!-- ✅ ADD ITEM (Under searching bar) -->
            <Button fx:id="btnAddItem"
                    text="Đăng sản phẩm"
                    styleClass="btn-orange"
                    onAction="#handleAddItem"
                    maxWidth="Infinity"/>

            <VBox spacing="10.0"
                  style="-fx-background-color: #2D3748; -fx-background-radius: 15; -fx-padding: 10;">
               <children>
                  <Button text="Tất cả" maxWidth="Infinity" styleClass="btn-orange"/>
                  <Button text="Đồng hồ" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
                  <Button text="Ô tô" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>

         <children>

            <!-- ✅ TOP RIGHT BAR (LOGOUT) -->
            <HBox alignment="CENTER_RIGHT" spacing="20">

               <!-- Left Card — Wallet Balance -->
               <HBox styleClass="header-card" alignment="CENTER_LEFT" spacing="15">
                   <HBox alignment="CENTER_LEFT" spacing="10">
                       <Label text="&#x1F4B3;" styleClass="wallet-icon"/>
                       <VBox alignment="CENTER_LEFT">
                           <Label text="Số dư ví:" styleClass="wallet-label"/>
                           <Label fx:id="lblBalance" text="\$0" styleClass="wallet-balance"/>
                       </VBox>
                   </HBox>
                   <Button fx:id="btnDeposit" text="NẠP" styleClass="btn-deposit-neon" onAction="#handleDeposit"/>
               </HBox>

               <!-- Right Card — User Profile -->
               <HBox styleClass="header-card" alignment="CENTER_LEFT" spacing="15">
                   <VBox alignment="CENTER_RIGHT">
                       <Label fx:id="lblUsername" text="seller" styleClass="profile-username"/>
                       <Label fx:id="lblRole" text="SELLER" styleClass="profile-role-badge"/>
                   </VBox>
                   <Label fx:id="lblAvatar" text="S" styleClass="profile-avatar"/>
                   <Button fx:id="btnLogout" styleClass="btn-logout-square" onAction="#handleLogout">
                       <graphic>
                           <Label text="&#x238B;" styleClass="logout-icon"/>
                       </graphic>
                   </Button>
               </HBox>

            </HBox>


            <!-- ✅ HEADER CHUẨN -->
            <HBox alignment="CENTER_LEFT" spacing="10">
               <Label text="Tất cả lô hàng"
                      style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />

               <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- ✅ GRID -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background: #0F131A; -fx-border-color: #0F131A;"
                        VBox.vgrow="ALWAYS">

               <content>
                  <FlowPane fx:id="itemGrid" hgap="30.0" vgap="30.0" />
               </content>
            </ScrollPane>

         </children>
      </VBox>
   </center>

   </BorderPane>

</StackPane>
