<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboard-root" stylesheets="@style.css"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.DashboardController">

   <left>
      <VBox prefWidth="250.0" spacing="20.0" styleClass="sidebar">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
         <children>
            <Label text="THE AUCTION SYSTEM"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField promptText="Tìm kiếm lô hàng..."
                       style="-fx-background-color: #2D3748; -fx-text-fill: white; -fx-background-radius: 10;" />

            <VBox spacing="10.0"
                  style="-fx-background-color: #2D3748; -fx-background-radius: 15; -fx-padding: 10;">
               <children>
                  <Button text="Tất cả" maxWidth="Infinity" styleClass="btn-orange"/>
                  <Button text="Đồng hồ" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
                  <Button text="Ô tô" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>

         <children>

            <!-- ✅ HEADER CHUẨN -->
            <HBox alignment="CENTER_LEFT" spacing="10">
               <Label text="Tất cả lô hàng"
                      style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />

               <Region HBox.hgrow="ALWAYS"/>

               <!-- ✅ CHỈ 1 BUTTON -->
               <Button fx:id="btnAddItem"
                       text="Đăng sản phẩm"
                       styleClass="btn-orange"
                       onAction="#handleAddItem"/>
            </HBox>

            <!-- ✅ GRID -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background: #0F131A; -fx-border-color: #0F131A;"
                        VBox.vgrow="ALWAYS">

               <content>
                  <FlowPane fx:id="itemGrid" hgap="30.0" vgap="30.0">

                     <children>

                        <!-- CARD DEMO -->
                        <VBox prefWidth="280.0" spacing="10.0" styleClass="item-card">
                           <padding>
                              <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                           </padding>

                           <children>
                              <HBox>
                                 <children>
                                    <Label text="LIVE" styleClass="badge-live"/>
                                 </children>
                              </HBox>

                              <Region prefHeight="150.0"
                                      style="-fx-background-color: #2D3748; -fx-background-radius: 10;" />

                              <Label text="LÔ-001 • ĐỒNG HỒ"
                                     style="-fx-text-fill: gray; -fx-font-size: 12px;" />

                              <Label text="Patek Philippe Grandmaster Chime"
                                     styleClass="card-title"
                                     wrapText="true"
                                     prefHeight="50.0"/>

                              <HBox alignment="BOTTOM_LEFT">
                                 <children>
                                    <VBox>
                                       <children>
                                          <Label text="GIÁ CAO NHẤT"
                                                 style="-fx-text-fill: gray; -fx-font-size: 10px;" />
                                          <Label text="\$15,500" styleClass="card-price"/>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>

                              <!-- ✅ NÚT VÀO PHÒNG -->
                              <Button text="Vào Phòng"
                                      maxWidth="Infinity"
                                      prefHeight="40.0"
                                      styleClass="btn-orange">
                                 <VBox.margin>
                                    <Insets top="10.0"/>
                                 </VBox.margin>
                              </Button>

                           </children>
                        </VBox>

                     </children>

                  </FlowPane>
               </content>
            </ScrollPane>

         </children>
      </VBox>
   </center>

</BorderPane>