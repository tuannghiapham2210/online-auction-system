<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.auction.DashboardController">

   <BorderPane styleClass="dashboard-root" stylesheets="@style.css">

   <left>
      <VBox prefWidth="250.0" spacing="20.0" styleClass="sidebar">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
         <children>
            <Label text="THE AUCTION SYSTEM"
                   style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" />

            <TextField fx:id="searchField"
                       promptText="Tìm kiếm lô hàng..."
                       style="-fx-background-color: #2D3748; -fx-text-fill: white; -fx-background-radius: 10;" />

            <!-- ✅ ADD ITEM (Under searching bar) -->
            <Button fx:id="btnAddItem"
                    text="Đăng sản phẩm"
                    styleClass="btn-orange"
                    onAction="#handleAddItem"
                    maxWidth="Infinity"/>

            <VBox spacing="10.0"
                  style="-fx-background-color: #2D3748; -fx-background-radius: 15; -fx-padding: 10;">
               <children>
                  <Button text="Tất cả" maxWidth="Infinity" styleClass="btn-orange"/>
                  <Button text="Đồng hồ" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
                  <Button text="Ô tô" maxWidth="Infinity"
                          style="-fx-background-color: transparent; -fx-text-fill: gray;"/>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>

         <children>

            <!-- ✅ TOP RIGHT BAR (LOGOUT) -->
            <HBox alignment="CENTER_RIGHT" spacing="15">

               <!-- Balance Indicator Pill -->
               <HBox alignment="CENTER" spacing="8" style="-fx-background-color: #1F2937; -fx-background-radius: 20; -fx-padding: 8 18; -fx-border-color: #374151; -fx-border-radius: 20;">
                   <Label text="💎" style="-fx-font-size: 14px;" />
                   <Label fx:id="lblBalance"
                          text="Số dư: $0"
                          style="-fx-text-fill: #34D399; -fx-font-size: 14px; -fx-font-weight: bold;" />
               </HBox>

               <!-- NẠP TIỀN -->
               <Button fx:id="btnDeposit"
                     text="Nạp Tiền"
                     styleClass="btn-deposit-pill"
                     onAction="#handleDeposit"/>

               <!-- ĐĂNG XUẤT -->
               <Button fx:id="btnLogout"
                     text="Đăng xuất"
                     styleClass="btn-logout-pill"
                     onAction="#handleLogout"/>

            </HBox>


            <!-- ✅ HEADER CHUẨN -->
            <HBox alignment="CENTER_LEFT" spacing="10">
               <Label text="Tất cả lô hàng"
                      style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />

               <Region HBox.hgrow="ALWAYS"/>
            </HBox>

            <!-- ✅ GRID -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background: #0F131A; -fx-border-color: #0F131A;"
                        VBox.vgrow="ALWAYS">

               <content>
                  <FlowPane fx:id="itemGrid" hgap="30.0" vgap="30.0" />
               </content>
            </ScrollPane>

         </children>
      </VBox>
   </center>

   </BorderPane>

</StackPane>
