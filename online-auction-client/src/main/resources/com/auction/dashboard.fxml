<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.DashboardController">

    <BorderPane styleClass="dashboard-root">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="20" styleClass="sidebar-premium">
                <padding>
                    <Insets left="25" right="25" top="20" bottom="10"/>
                </padding>
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="16">
                        <Label styleClass="logo-icon-premium" text="&#x269C;" />
                        <VBox spacing="2">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label style="-fx-text-fill: white; -fx-font-size: 32px; -fx-font-weight: 900;" text="THE AUCTION" />
                                <Label style="-fx-text-fill: #F59E0B; -fx-font-size: 32px; -fx-font-weight: 900;" text="SYSTEM" />
                            </HBox>
                            <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 14px;" text="Sàn đấu giá trực tuyến. Khám phá các lô hàng cao cấp." wrapText="true" />
                        </VBox>
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <HBox alignment="CENTER_RIGHT" spacing="20">
                        <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #1E293B; -fx-background-radius: 12; -fx-padding: 5 15; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12;">
                            <Label style="-fx-text-fill: #34D399; -fx-font-size: 20px;" text="💳" />
                            <VBox alignment="CENTER_LEFT">
                                <Label style="-fx-text-fill: #94A3B8; -fx-font-size: 10px;" text="Số dư ví:" />
                                <Label fx:id="lblBalance" style="-fx-text-fill: #34D399; -fx-font-size: 16px; -fx-font-weight: bold;" text="\$0" />
                            </VBox>
                            <Button fx:id="btnDeposit" onAction="#handleDeposit" style="-fx-background-color: transparent; -fx-border-color: #34D399; -fx-text-fill: #34D399; -fx-border-radius: 8; -fx-font-weight: bold; -fx-cursor: hand;" text="NẠP" />
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15" styleClass="header-card">
                            <VBox alignment="CENTER_RIGHT">
                                <Label fx:id="lblUsername" styleClass="profile-username" text="seller" />
                                <Label fx:id="lblRole" styleClass="profile-role-badge" text="SELLER" />
                            </VBox>
                            <Label fx:id="lblAvatar" styleClass="profile-avatar" text="S" />
                            <Button fx:id="btnLogout" onAction="#handleLogout" styleClass="btn-logout-square">
                                <graphic>
                                    <Label styleClass="logout-icon" text="&#x238B;" />
                                </graphic>
                            </Button>
                        </HBox>
                    </HBox>
                </children>
            </HBox>
        </top>

        <left>
            <VBox prefWidth="260" spacing="20" styleClass="sidebar-premium">
                <padding>
                    <Insets bottom="30" left="15" right="15" top="10" />
                </padding>
                <children>
                    <Region maxWidth="Infinity" prefHeight="1" style="-fx-background-color: linear-gradient(to right, #F59E0B 0%, rgba(245,158,11,0.22) 45%, transparent 100%);" />

                    <VBox spacing="20" VBox.vgrow="ALWAYS">

                        <HBox alignment="CENTER_LEFT" styleClass="search-box-premium">
                            <Label styleClass="search-icon-premium" text="&#x1F50D;" />
                            <TextField fx:id="searchField" promptText="Tìm kiếm..." styleClass="search-field-premium" HBox.hgrow="ALWAYS" />
                        </HBox>

                        <VBox spacing="4" styleClass="category-container-premium">
                            <Label text="DANH MỤC" style="-fx-text-fill: #64748B; -fx-font-size: 11px; -fx-font-weight: 800; -fx-padding: 0 0 8 10; -fx-letter-spacing: 1px;" />

                            <Button fx:id="btnFilterAll" onAction="#filterAll" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-active" text="&#x2756;   Tất cả" />
                            <Button fx:id="btnFilterArt" onAction="#filterArt" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-inactive" text="&#x1F3A8;   Art" />
                            <Button fx:id="btnFilterVehicle" onAction="#filterVehicle" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-inactive" text="&#x1F697;   Vehicle" />
                            <Button fx:id="btnFilterElectronics" onAction="#filterElectronics" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-inactive" text="&#x1F4BB;   Electronics" />
                            <Button fx:id="btnFilterOther" onAction="#filterOther" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-inactive" text="&#x1F4A1;   Other" />
                            <Button fx:id="btnFilterFinished" onAction="#filterFinished" alignment="BASELINE_LEFT" maxWidth="Infinity" styleClass="menu-item-inactive" text="&#x1F3C1;   Đã hoàn thành" />
                        </VBox>

                        <Button fx:id="btnAddItem" maxWidth="Infinity" onAction="#handleAddItem" styleClass="btn-outline-add" text="&#x2795; ĐĂNG BÁN SẢN PHẨM" />

                        <Region VBox.vgrow="ALWAYS" />

                    </VBox>
                </children>
            </VBox>
        </left>

        <center>
            <VBox spacing="25.0">
                <padding>
                    <Insets bottom="40.0" left="40.0" right="40.0" top="20.0" />
                </padding>
                <children>
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <Label style="-fx-text-fill: white; -fx-font-size: 28px; -fx-font-weight: 900; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0, 0, 2);" text="Tất cả lô hàng" />
                        <Label fx:id="lblItemCount" style="-fx-text-fill: #94A3B8; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-color: #1E293B; -fx-padding: 2 10; -fx-background-radius: 12;" text="(0)" />
                        <Region HBox.hgrow="ALWAYS" />
                    </HBox>

                    <ScrollPane fitToWidth="true" styleClass="premium-scroll-pane" VBox.vgrow="ALWAYS">
                        <content>
                            <FlowPane fx:id="itemGrid" hgap="30.0" vgap="30.0" style="-fx-padding: 10 0 10 0;" />
                        </content>
                    </ScrollPane>
                </children>
            </VBox>
        </center>

    </BorderPane>

    <!-- Lớp phủ tối mờ nền chuẩn MVC -->
    <Region fx:id="darkOverlay" visible="false" styleClass="dialog-overlay" />

    <!-- Menu thả xuống của Avatar tĩnh chuẩn FXML -->
    <fx:include fx:id="profileDropdown" source="profile_dropdown.fxml" StackPane.alignment="TOP_RIGHT" visible="false">
        <StackPane.margin>
            <Insets top="96" right="8" bottom="0" left="0"/>
        </StackPane.margin>
    </fx:include>

</StackPane>