<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="dashboard-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.DashboardController">
   
   <left>
      <VBox prefWidth="250.0" spacing="20.0" styleClass="sidebar" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="30.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold;" text="THE AUCTION SYSTEM" />
            <TextField promptText="Tìm kiếm lô hàng..." style="-fx-background-color: #2D3748; -fx-text-fill: white; -fx-background-radius: 10;" />
            <VBox spacing="10.0" style="-fx-background-color: #2D3748; -fx-background-radius: 15; -fx-padding: 10;">
               <children>
                  <Button maxWidth="Infinity" styleClass="btn-orange" text="Tất cả" />
                  <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: gray;" text="Đồng hồ" />
                  <Button maxWidth="Infinity" style="-fx-background-color: transparent; -fx-text-fill: gray;" text="Ô tô" />
               </children>
            </VBox>
         </children>
      </VBox>
   </left>

   <center>
      <VBox spacing="20.0" BorderPane.alignment="CENTER">
         <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
         </padding>
         <children>
            <Label style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" text="Tất cả lô hàng" />
            
            <ScrollPane fitToWidth="true" style="-fx-background: #0F131A; -fx-border-color: #0F131A;" VBox.vgrow="ALWAYS">
               <content>
                  <FlowPane fx:id="itemGrid" hgap="30.0" vgap="30.0">
                     <children>
                        
                        <VBox prefWidth="280.0" spacing="10.0" styleClass="item-card">
                           <padding>
                              <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                           </padding>
                           <children>
                              <HBox>
                                 <children>
                                    <Label styleClass="badge-live" text="LIVE" />
                                 </children>
                              </HBox>
                              <Region prefHeight="150.0" style="-fx-background-color: #2D3748; -fx-background-radius: 10;" />
                              <Label style="-fx-text-fill: gray; -fx-font-size: 12px;" text="LÔ-001 • ĐỒNG HỒ" />
                              <Label prefHeight="50.0" styleClass="card-title" text="Patek Philippe Grandmaster Chime" wrapText="true" />
                              <HBox alignment="BOTTOM_LEFT">
                                 <children>
                                    <VBox>
                                       <children>
                                          <Label style="-fx-text-fill: gray; -fx-font-size: 10px;" text="GIÁ CAO NHẤT" />
                                          <Label styleClass="card-price" text="\$15,500" />
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              <Button maxWidth="Infinity" prefHeight="40.0" styleClass="btn-orange" text="Vào Phòng">
                                 <VBox.margin>
                                    <Insets top="10.0" />
                                 </VBox.margin>
                              </Button>
                           </children>
                        </VBox>
                        </children>
                  </FlowPane>
               </content>
            </ScrollPane>
         </children>
      </VBox>
   </center>
</BorderPane>