<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.auction.LoginController">

   <padding>
      <Insets top="20" right="20" bottom="20" left="20"/>
   </padding>

   <Label text="ĐĂNG NHẬP"
          style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

   <TextField fx:id="usernameField" promptText="Tên đăng nhập"/>

   <PasswordField fx:id="passwordField" promptText="Mật khẩu"/>

   <Button text="Đăng nhập" onAction="#handleLogin"/>

   <Button text="Chưa có tài khoản? Đăng ký"
           onAction="#goToRegister"/>

   <Label fx:id="messageLabel"/>

</VBox>