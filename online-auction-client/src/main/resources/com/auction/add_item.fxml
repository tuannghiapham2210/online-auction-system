<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgba(15, 23, 42, 0.8);" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.AddItemController">
    <children>

        <VBox maxWidth="500.0" maxHeight="600.0" spacing="20.0" style="-fx-background-color: #1f2937; -fx-background-radius: 12; -fx-border-radius: 12; -fx-border-color: #374151; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 20, 0, 0, 10);">
            <padding>
                <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="⊕" textFill="#fbbf24">
                    <font>
                        <Font name="System Bold" size="22.0" />
                    </font>
                </Label>
                <Label text="TẠO PHIÊN ĐẤU GIÁ" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="18.0" />
                    </font>
                </Label>
                <Region HBox.hgrow="ALWAYS" />
                <Button style="-fx-background-color: #374151; -fx-text-fill: #9ca3af; -fx-background-radius: 50; -fx-cursor: hand;" text="✕" />
            </HBox>

            <VBox spacing="8.0">
                <Label text="TÊN SẢN PHẨM *" textFill="#9ca3af">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                </Label>
                <TextField fx:id="nameField" prefHeight="40.0" promptText="Nhập tên sản phẩm..." style="-fx-background-color: #111827; -fx-text-fill: white; -fx-border-color: #374151; -fx-border-radius: 6;" />
            </VBox>

            <HBox spacing="15.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="DANH MỤC *" textFill="#9ca3af">
                        <font>
                            <Font name="System Bold" size="11.0" />
                        </font>
                    </Label>
                    <ComboBox fx:id="typeComboBox" maxWidth="1.7976931348623157E308" prefHeight="40.0" style="-fx-background-color: #111827; -fx-border-color: #374151; -fx-border-radius: 6;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="GIÁ KHỞI ĐIỂM ($) *" textFill="#9ca3af">
                        <font>
                            <Font name="System Bold" size="11.0" />
                        </font>
                    </Label>
                    <TextField fx:id="priceField" prefHeight="40.0" promptText="\$" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-border-color: #374151; -fx-border-radius: 6;" />
                </VBox>
            </HBox>

            <HBox spacing="15.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="THỜI GIAN KẾT THÚC *" textFill="#9ca3af">
                        <font>
                            <Font name="System Bold" size="11.0" />
                        </font>
                    </Label>
                    <TextField fx:id="endTimeField" prefHeight="40.0" promptText="YYYY-MM-DD HH:MM:SS" style="-fx-background-color: #111827; -fx-text-fill: white; -fx-border-color: #374151; -fx-border-radius: 6;" />
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label text="THÔNG TIN THÊM" textFill="#9ca3af">
                        <font>
                            <Font name="System Bold" size="11.0" />
                        </font>
                    </Label>
                    <TextField fx:id="extraInfoField" prefHeight="40.0" promptText="Bảo hành/Tác giả..." style="-fx-background-color: #111827; -fx-text-fill: white; -fx-border-color: #374151; -fx-border-radius: 6;" />
                </VBox>
            </HBox>

            <VBox spacing="8.0">
                <Label text="THÔNG TIN CHI TIẾT" textFill="#9ca3af">
                    <font>
                        <Font name="System Bold" size="11.0" />
                    </font>
                </Label>
                <TextArea fx:id="descriptionArea" prefHeight="80.0" promptText="Mô tả sản phẩm..." style="-fx-control-inner-background: #111827; -fx-text-fill: white; -fx-border-color: #374151; -fx-border-radius: 6;" wrapText="true" />
            </VBox>

            <HBox alignment="CENTER" spacing="15.0" translateY="5.0">
                <Button prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #374151; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Hủy" />
                <Button fx:id="submitButton" onAction="#handleSubmit" prefHeight="40.0" prefWidth="140.0" style="-fx-background-color: #f59e0b; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;" text="Tạo Phiên" />
            </HBox>
        </VBox>
    </children>
</StackPane>