<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane style="-fx-background-color: transparent;" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.AddItemController">
    <children>
        <VBox maxWidth="650.0" maxHeight="-Infinity" spacing="20.0" styleClass="modal-container">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <!-- Tiêu đề được tách để chỉnh màu icon ⊕ -->
            <HBox alignment="CENTER_LEFT">
                <Label style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" text="⊕" />
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 0 8;" text="TẠO PHIÊN ĐẤU GIÁ" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#closePopup" styleClass="btn-close-circle" text="✕" />
            </HBox>

            <VBox spacing="8.0">
                <Label styleClass="target-label" text="- TÊN SẢN PHẨM *" />
                <HBox styleClass="target-input-box">
                    <Label styleClass="target-input-icon" text="&#x1F3F7;" />
                    <TextField fx:id="nameField" promptText="Nhập tên sản phẩm..." styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <HBox spacing="20.0">
                <VBox prefWidth="280" spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="target-label" text="- DANH MỤC *" />
                    <ComboBox fx:id="typeComboBox" maxWidth="Infinity" promptText="Danh mục sản phẩm" styleClass="target-combo-box" />
                </VBox>
                <VBox prefWidth="280" spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="target-label" text="- HÌNH ẢNH (URL)" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="&#x1F5BC;" />
                        <TextField fx:id="imageUrlField" promptText="https://..." styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                        <Button text="Chọn file" onAction="#handleBrowseImage" style="-fx-background-color: #4B5563; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand; -fx-padding: 4 8;" />
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="8.0">
                <Label styleClass="target-label" text="- MÔ TẢ" />

                <!-- Thêm alignment="TOP_LEFT" để ép các thành phần bên trong nổi lên trên cùng -->
                <HBox alignment="TOP_LEFT" styleClass="target-input-box">

                    <!-- Dùng mã &#x2139; cho icon Information (ℹ), thêm minWidth để không bị 3 chấm -->
                    <Label styleClass="target-input-icon" text="&#x2139;" minWidth="-Infinity">
                        <!-- Đẩy icon xuống 12px để ngang hàng với padding của TextArea -->
                        <HBox.margin>
                            <Insets top="12.0" />
                        </HBox.margin>
                    </Label>

                    <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Mô tả tình trạng, nguồn gốc..." styleClass="target-textarea" wrapText="true" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- Đã xóa Separator ở đây theo đúng mẫu Ảnh 2 -->

            <HBox spacing="15.0">
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="target-label" text="- GIÁ KHỞI ĐIỂM ($) *" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="\$" />
                        <TextField fx:id="priceField" promptText="VD: 5000" styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="target-label" text="- BƯỚC GIÁ ($) *" />
                    <HBox styleClass="target-input-box">
                        <!-- Thêm minWidth="-Infinity" và dùng ký tự mũi tên đơn giản -->
                        <Label styleClass="target-input-icon" text="↗" minWidth="-Infinity" />
                        <TextField fx:id="stepPriceField" promptText="VD: 500" styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>

                <VBox spacing="8.0" HBox.hgrow="ALWAYS">
                    <Label styleClass="target-label" text="- THỜI GIAN (HH:MM:SS) *" />

                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="🕒" minWidth="-Infinity" />
                        <TextField fx:id="durationField"
                                promptText="00:00:00"
                                text="00:00:00"
                                styleClass="target-textfield"
                                HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 0 0 0 5;" />

            <HBox spacing="20.0" translateY="5.0">
                <Button maxWidth="Infinity" onAction="#closePopup" styleClass="btn-target-cancel" text="Hủy" HBox.hgrow="ALWAYS" />
                <Button maxWidth="Infinity" onAction="#handleSubmit" styleClass="btn-target-submit" text="Tạo Phiên Đấu Giá" HBox.hgrow="ALWAYS" />
            </HBox>

        </VBox>
    </children>
</StackPane>
