<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="720.0" prefWidth="1280.0" style="-fx-background-color: rgba(10, 15, 25, 0.8);" stylesheets="@style.css" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.AddItemController">
    <children>
        <VBox maxWidth="650.0" spacing="20.0" styleClass="modal-container">
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>

            <!-- Tiêu đề được tách để chỉnh màu icon ⊕ -->
            <HBox alignment="CENTER_LEFT">
                <Label style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" text="⊕" />
                <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: white; -fx-padding: 0 0 0 8;" text="TẠO PHIÊN ĐẤU GIÁ" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#closePopup" styleClass="btn-close-circle" text="✕" />
            </HBox>

            <VBox spacing="8.0">
                <Label styleClass="target-label" text="- TÊN SẢN PHẨM *" />
                <HBox styleClass="target-input-box">
                    <Label styleClass="target-input-icon" text="🏷" />
                    <TextField fx:id="nameField" promptText="Nhập tên sản phẩm..." styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <HBox spacing="20.0">
                <VBox HBox.hgrow="ALWAYS" spacing="8.0" prefWidth="280">
                    <Label styleClass="target-label" text="- DANH MỤC *" />
                    <ComboBox fx:id="typeComboBox" maxWidth="1.7976931348623157E308" promptText="Đồng hồ" styleClass="target-combo-box" />
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="8.0" prefWidth="280">
                    <Label styleClass="target-label" text="- HÌNH ẢNH (URL)" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="🖼" />
                        <TextField fx:id="imageUrlField" promptText="https://..." styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </HBox>

            <VBox spacing="8.0">
                <Label styleClass="target-label" text="- MÔ TẢ" />
                <HBox alignment="TOP_LEFT" styleClass="target-input-box">
                    <Label styleClass="target-input-icon" text="≡" translateY="10" />
                    <TextArea fx:id="descriptionArea" prefRowCount="3" promptText="Mô tả tình trạng, nguồn gốc..." styleClass="target-textarea" wrapText="true" HBox.hgrow="ALWAYS" />
                </HBox>
            </VBox>

            <!-- Đã xóa Separator ở đây theo đúng mẫu Ảnh 2 -->

            <HBox spacing="15.0">
                <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                    <Label styleClass="target-label" text="- GIÁ KHỞI ĐIỂM ($) *" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="\$" />
                        <TextField fx:id="priceField" promptText="VD: 5000" styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                    <Label styleClass="target-label" text="- BƯỚC GIÁ ($) *" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="↗" />
                        <TextField fx:id="stepPriceField" promptText="VD: 500" styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
                <VBox HBox.hgrow="ALWAYS" spacing="8.0">
                    <Label styleClass="target-label" text="- THỜI GIAN (HOURS) *" />
                    <HBox styleClass="target-input-box">
                        <Label styleClass="target-input-icon" text="🕒" />
                        <TextField fx:id="durationField" promptText="VD: 24" styleClass="target-textfield" HBox.hgrow="ALWAYS" />
                    </HBox>
                </VBox>
            </HBox>

            <Label fx:id="messageLabel" style="-fx-text-fill: #ef4444; -fx-font-weight: bold; -fx-padding: 0 0 0 5;" />

            <HBox spacing="20.0" translateY="5.0">
                <Button maxWidth="1.7976931348623157E308" onAction="#closePopup" styleClass="btn-target-cancel" text="Hủy" HBox.hgrow="ALWAYS" />
                <Button maxWidth="1.7976931348623157E308" onAction="#handleSubmit" styleClass="btn-target-submit" text="Tạo Phiên Đấu Giá" HBox.hgrow="ALWAYS" />
            </HBox>

        </VBox>
    </children>
</StackPane>