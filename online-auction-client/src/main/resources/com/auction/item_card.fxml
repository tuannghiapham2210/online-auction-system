<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.shape.SVGPath?>

<VBox fx:id="cardRoot" prefWidth="280.0" spacing="0" styleClass="item-card" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.ItemCardController">
    <children>
        <StackPane fx:id="imageContainer" maxHeight="180.0" minHeight="180.0" prefHeight="180.0" style="-fx-padding: 0; -fx-background-color: white; -fx-background-radius: 12 12 0 0;">
            <children>
                <Rectangle fx:id="imageRect" fill="WHITE" />
                <Label fx:id="badgeLabel" StackPane.alignment="TOP_LEFT">
                    <StackPane.margin>
                        <Insets left="10.0" top="10.0" />
                    </StackPane.margin>
                </Label>
                <HBox fx:id="viewerBadge" alignment="CENTER" maxWidth="-Infinity" maxHeight="-Infinity" spacing="5.0" style="-fx-background-color: rgba(0, 0, 0, 0.6); -fx-background-radius: 12px; -fx-padding: 5 12;" StackPane.alignment="TOP_RIGHT">
                    <StackPane.margin>
                        <Insets right="10.0" top="10.0" />
                    </StackPane.margin>
                    <children>
                        <SVGPath content="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z" fill="#8B949E" />
                        <Label fx:id="viewerCountLabel" style="-fx-text-fill: #8B949E; -fx-font-size: 11px; -fx-font-weight: bold;" />
                    </children>
                </HBox>
            </children>
        </StackPane>
        <VBox spacing="10.0">
            <padding>
                <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
            </padding>
            <children>
                <HBox>
                    <children>
                        <Label fx:id="lotBadge" style="-fx-text-fill: #FFA500; -fx-background-color: #151821; -fx-padding: 3 6; -fx-background-radius: 4;" />
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="typeBadge" style="-fx-text-fill: #8B949E; -fx-background-color: #151821; -fx-padding: 3 6; -fx-background-radius: 4;" />
                    </children>
                </HBox>
                <Label fx:id="titleLabel" prefHeight="50.0" styleClass="card-title" wrapText="true" />
                <HBox>
                    <children>
                        <VBox><children><Label fx:id="priceTitleLabel" style="-fx-text-fill: gray; -fx-font-size: 10;" /><Label fx:id="priceLabel" style="-fx-text-fill: white;" styleClass="card-price" /></children></VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <VBox alignment="CENTER_RIGHT"><children><Label style="-fx-text-fill: gray; -fx-font-size: 10;" text="CÒN LẠI" /><Label fx:id="timerLabel" style="-fx-text-fill: #EF4444; -fx-font-size: 12px; -fx-font-weight: bold;" text="⏳ Đang tải..." /></children></VBox>
                    </children>
                </HBox>
                <HBox fx:id="actionRow" alignment="CENTER" maxWidth="1.7976931348623157E308" spacing="10.0">
                    <children>
                        <Button fx:id="btnEnter" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" />
                        <Button fx:id="btnDelete" managed="false" prefHeight="38.0" prefWidth="75.0" style="-fx-background-color: #EF4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-size: 13px;" text="🗑 Gỡ" visible="false" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</VBox>