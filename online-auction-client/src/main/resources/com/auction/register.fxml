<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane fx:id="rootPane" styleClass="background" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/17.0.12" fx:controller="com.auction.controller.RegisterController">

    <VBox alignment="CENTER" spacing="30">

        <!-- HEADER -->
        <VBox alignment="CENTER" spacing="5">
            <Label styleClass="logo-icon-premium" text="&#x269C;" />
            <HBox fx:id="titleHbox" alignment="CENTER" maxWidth="-Infinity">
                <Label styleClass="title" text="THE AUCTION" />
                <Label styleClass="title-accent" text=" SYSTEM" />
            </HBox>
            <Label styleClass="header-sub" text="Tham gia đấu giá ngay hôm nay" />
        </VBox>

        <!-- CARD -->
        <VBox fx:id="cardVbox" alignment="CENTER" spacing="20" styleClass="card">


            <!-- TAB -->
            <HBox alignment="CENTER" spacing="5" styleClass="tab-container">
                <Label onMouseClicked="#goToLogin" styleClass="switch-btn" text="Đăng Nhập" />
                <Label styleClass="switch-active" text="Đăng Ký" />
            </HBox>

            <!-- USERNAME -->
            <HBox maxWidth="Infinity" styleClass="input-box">
                <Label styleClass="input-icon" text="👤" />
                <TextField fx:id="usernameField" maxWidth="Infinity" prefHeight="43.0" HBox.hgrow="ALWAYS" promptText="Nhập tài khoản" />
            </HBox>

            <!-- PASSWORD -->
            <HBox maxWidth="Infinity" styleClass="input-box">
                <Label styleClass="input-icon" text="🔒" />
                <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="43.0" HBox.hgrow="ALWAYS" promptText="Nhập mật khẩu" />
            </HBox>

        <!-- EMAIL (TÙY CHỌN) -->
        <HBox maxWidth="Infinity" styleClass="input-box">
            <Label styleClass="input-icon" text="📧" />
            <TextField fx:id="emailField" maxWidth="Infinity" prefHeight="43.0" HBox.hgrow="ALWAYS" promptText="Email (Tùy chọn)" />
        </HBox>

        <!-- SỐ ĐIỆN THOẠI (TÙY CHỌN) -->
        <HBox maxWidth="Infinity" styleClass="input-box">
            <Label styleClass="input-icon" text="📞" />
            <TextField fx:id="phoneField" maxWidth="Infinity" prefHeight="43.0" HBox.hgrow="ALWAYS" promptText="Số điện thoại (Tùy chọn)" />
        </HBox>

            <!-- ROLE -->
        <fx:define>
            <ToggleGroup fx:id="roleToggleGroup"/>
        </fx:define>
        <HBox spacing="15" maxWidth="Infinity">
            <ToggleButton fx:id="btnBidder" text="Người mua (Bidder)" toggleGroup="$roleToggleGroup" styleClass="role-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" contentDisplay="TOP">
                <graphic>
                    <Label text="🛒" styleClass="role-card-icon" />
                </graphic>
            </ToggleButton>
            <ToggleButton fx:id="btnSeller" text="Người bán (Seller)" toggleGroup="$roleToggleGroup" styleClass="role-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" contentDisplay="TOP">
                <graphic>
                    <Label text="🏪" styleClass="role-card-icon" />
                </graphic>
            </ToggleButton>
        </HBox>

            <!-- BUTTON -->
            <Button fx:id="registerButton" defaultButton="true" maxWidth="Infinity" onAction="#handleRegister" styleClass="main-btn" text="Tham gia ngay" />

            <Label onMouseClicked="#goToLogin" styleClass="switch-btn" text="Quay lại đăng nhập" />

            <Label fx:id="messageLabel" />

        </VBox>
    </VBox>

</StackPane>
