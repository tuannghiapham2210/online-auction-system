<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="alertRoot" alignment="CENTER" spacing="15.0" styleClass="alert-root" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.CustomAlertController">
   <padding>
      <Insets bottom="20.0" left="25.0" right="25.0" top="25.0" />
   </padding>
   <children>
      <Label fx:id="iconLabel" styleClass="alert-icon" />
      <Label fx:id="titleLabel" styleClass="alert-title" />
      <Label fx:id="msgLabel" styleClass="alert-msg" />
      <HBox alignment="CENTER" spacing="15.0">
         <children>
            <Button fx:id="btnConfirm" onAction="#handleConfirm" styleClass="alert-btn-confirm" />
            <Button fx:id="btnCancel" onAction="#handleCancel" styleClass="alert-btn-cancel" text="Hủy" />
         </children>
      </HBox>
   </children>
</VBox>