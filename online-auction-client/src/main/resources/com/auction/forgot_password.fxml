<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootVBox" stylesheets="@style.css" spacing="16" styleClass="modal-container" maxWidth="460" maxHeight="-Infinity" xmlns:fx="http://javafx.com/fxml" fx:controller="com.auction.controller.ForgotPasswordController" style="-fx-padding: 30 35;">

   <!-- Header -->
   <HBox alignment="CENTER_LEFT">
       <Label text="Khôi Phục Mật Khẩu" style="-fx-text-fill: #F59E0B; -fx-font-size: 22px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
       <Button text="✕" styleClass="btn-close-circle" onAction="#handleClose"/>
   </HBox>

   <VBox spacing="4">
       <Label text="Nhập Tên đăng nhập và Email hoặc Số điện thoại để khôi phục." wrapText="true" style="-fx-text-fill: #9CA3AF; -fx-font-size: 14px;"/>
       <Label text="(Lưu ý: Nếu tài khoản chưa từng liên kết Email/SĐT thì sẽ không thể khôi phục bằng cách này)" wrapText="true" style="-fx-text-fill: #6B7280; -fx-font-size: 12px; -fx-font-style: italic;"/>
   </VBox>

   <!-- Username -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="👤" />
       <TextField fx:id="tfUsername" promptText="Tên đăng nhập" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- Contact Info -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="📧" />
       <TextField fx:id="tfContactInfo" promptText="Email hoặc Số điện thoại xác thực" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- New Password -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="🔒" />
       <PasswordField fx:id="tfNewPassword" promptText="Mật khẩu mới" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- Confirm Password -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="✓" />
       <PasswordField fx:id="tfConfirmPassword" promptText="Xác nhận mật khẩu mới" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <Label fx:id="lblMessage" styleClass="forgot-password-msg" managed="false" visible="false" wrapText="true"/>

   <!-- Buttons -->
   <Button defaultButton="true" text="Khôi Phục Ngay" styleClass="main-btn" maxWidth="Infinity" onAction="#handleReset" style="-fx-padding: 10; -fx-font-size: 15px;"/>

</VBox>