<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox fx:id="rootVBox" stylesheets="@style.css" spacing="12" styleClass="modal-container" maxWidth="400" maxHeight="-Infinity" xmlns:fx="http://javafx.com/fxml" fx:controller="com.auction.ForgotPasswordController" style="-fx-padding: 20 25;">

   <!-- Header -->
   <HBox alignment="CENTER_LEFT">
       <Label text="Khôi Phục Mật Khẩu" style="-fx-text-fill: #F59E0B; -fx-font-size: 22px; -fx-font-weight: bold;" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
       <Button text="✕" styleClass="btn-close-circle" onAction="#handleClose"/>
   </HBox>

   <Label text="Nhập tên đăng nhập và số điện thoại (đã liên kết) để đặt lại mật khẩu mới." wrapText="true" style="-fx-text-fill: #9CA3AF; -fx-font-size: 13px;"/>

   <!-- Username -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="👤" />
       <TextField fx:id="tfUsername" promptText="Tên đăng nhập" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- Phone -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="📞" />
       <TextField fx:id="tfPhone" promptText="Số điện thoại xác thực" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- New Password -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="🔒" />
       <PasswordField fx:id="tfNewPassword" promptText="Mật khẩu mới" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <!-- Confirm Password -->
   <HBox styleClass="input-box">
       <Label styleClass="input-icon" text="✓" />
       <PasswordField fx:id="tfConfirmPassword" promptText="Xác nhận mật khẩu mới" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-prompt-text-fill: #64748b; -fx-padding: 10 10; -fx-border-width: 0;" HBox.hgrow="ALWAYS"/>
   </HBox>

   <Label fx:id="lblMessage" managed="false" visible="false" wrapText="true"/>

   <!-- Buttons -->
   <Button defaultButton="true" text="Khôi Phục Ngay" styleClass="main-btn" maxWidth="Infinity" onAction="#handleReset" style="-fx-padding: 10; -fx-font-size: 15px;"/>

</VBox>