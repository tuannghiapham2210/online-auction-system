<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tooltip?>

<!-- Tách biệt hoàn toàn giao diện điểm biểu đồ (Chart Node) ra khỏi Java Code -->
<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.ChartNodeController" styleClass="chart-node-pane">
    <!-- Khai báo Tooltip ngầm (tuân thủ MVC, không cần dùng Label đệm) -->
    <fx:define>
        <Tooltip fx:id="dotTooltip" styleClass="chart-tooltip"/>
    </fx:define>
    <!-- Trả lại thẻ Circle nguyên thủy, fix cứng thuộc tính vector để đảm bảo sắc nét 100% -->
    <Circle fx:id="dotNode" radius="6" fill="#f9a825" stroke="WHITE" strokeWidth="2" styleClass="chart-node-dot" />
    <Label fx:id="priceLabel" id="priceLabel" styleClass="chart-node-label" />
</StackPane>