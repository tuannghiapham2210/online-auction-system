<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.PasswordChangeController"
      alignment="CENTER"
      spacing="18"
      maxWidth="360"
      styleClass="modal-container"
      style="-fx-padding: 24; -fx-background-color: #212936; -fx-border-color: #2A3441; -fx-border-width: 1; -fx-border-radius: 12; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 20, 0, 0, 10);">

    <Label text="Đổi mật khẩu" style="-fx-text-fill: #F59E0B; -fx-font-size: 24px; -fx-font-weight: bold;" />

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Mật khẩu hiện tại" style="-fx-text-fill: #E2E8F0; -fx-font-size: 13px; -fx-font-weight: bold;" />
        <PasswordField fx:id="tfOldPassword" promptText="Nhập mật khẩu hiện tại"
                       style="-fx-background-color: #1F2937; -fx-text-fill: #E2E8F0; -fx-border-color: #334155; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />
    </VBox>

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Mật khẩu mới" style="-fx-text-fill: #E2E8F0; -fx-font-size: 13px; -fx-font-weight: bold;" />
        <PasswordField fx:id="tfNewPassword" promptText="Nhập mật khẩu mới"
                       style="-fx-background-color: #1F2937; -fx-text-fill: #E2E8F0; -fx-border-color: #334155; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />
    </VBox>

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Xác nhận mật khẩu" style="-fx-text-fill: #E2E8F0; -fx-font-size: 13px; -fx-font-weight: bold;" />
        <PasswordField fx:id="tfConfirmPassword" promptText="Nhập lại mật khẩu mới"
                       style="-fx-background-color: #1F2937; -fx-text-fill: #E2E8F0; -fx-border-color: #334155; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 10;" />
    </VBox>

    <Label fx:id="lblMessage" text="" wrapText="true" maxWidth="320" visible="false" style="-fx-font-size: 12px;" />

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-background-color: transparent;">
        <Button text="Hủy" onAction="#handleClose"
                style="-fx-background-color: #334155; -fx-text-fill: #E2E8F0; -fx-font-weight: bold; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 10 20; -fx-cursor: hand; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />
        <Button text="Lưu" onAction="#handleSave"
                style="-fx-background-color: #F59E0B; -fx-text-fill: black; -fx-font-weight: bold; -fx-background-radius: 16; -fx-border-radius: 16; -fx-padding: 10 20; -fx-cursor: hand; -fx-focus-color: transparent; -fx-faint-focus-color: transparent;" />
    </HBox>

</VBox>
