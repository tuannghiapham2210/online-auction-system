<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.geometry.Pos?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17.0.2" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.PasswordChangeController"
      stylesheets="@style.css"
      alignment="CENTER"
      spacing="18"
      prefWidth="360"
      prefHeight="420"
      minWidth="360"
      maxWidth="360"
      minHeight="420"
      maxHeight="420"
      styleClass="modal-container, password-change-root">

    <Label text="Đổi mật khẩu" styleClass="password-change-title" />

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Mật khẩu hiện tại" styleClass="password-change-field-label" />
        <PasswordField fx:id="tfOldPassword" promptText="Nhập mật khẩu hiện tại" styleClass="password-change-input" />
    </VBox>

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Mật khẩu mới" styleClass="password-change-field-label" />
        <PasswordField fx:id="tfNewPassword" promptText="Nhập mật khẩu mới" styleClass="password-change-input" />
    </VBox>

    <VBox spacing="12" maxWidth="Infinity">
        <Label text="Xác nhận mật khẩu" styleClass="password-change-field-label" />
        <PasswordField fx:id="tfConfirmPassword" promptText="Nhập lại mật khẩu mới" styleClass="password-change-input" />
    </VBox>

    <Label fx:id="lblMessage" text="" wrapText="true" maxWidth="320" visible="false" styleClass="password-change-msg" />

    <HBox spacing="10" alignment="CENTER_RIGHT" style="-fx-background-color: transparent;">
        <Button text="Hủy" onAction="#handleClose" styleClass="btn-password-cancel" />
        <Button text="Lưu" onAction="#handleSave" styleClass="btn-password-save" />
    </HBox>

</VBox>
